generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Hero {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  tagline      String
  bio          String
  roles        String[]
  profileImage String
  isAvailable  Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model About {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  bio1             String
  bio2             String
  projectsCount    String
  yearsExperience  String
  location         String
  jobTitle         String
  training         String
  availability     String
  resumeUrl        String
  updatedAt        DateTime @updatedAt
}

model Education {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  degree      String
  institution String
  location    String
  duration    String
  gpa         String?
  status      String
  description String
  coursework  String[]
  color       String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Certificate {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  provider String
  icon     String  @default("")
  iconUrl  String  @default("")
  order    Int     @default(0)
}

model Project {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  category     String
  description  String
  image        String
  technologies String[]
  liveUrl      String
  githubUrl    String
  order        Int      @default(0)
  createdAt    DateTime @default(now())
}

model Skill {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  name    String @default("")
  icon    String @default("")
  iconUrl String @default("")
  order   Int    @default(0)
}

model SocialLink {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  label String
  href  String
  icon  String // store icon name as string e.g. "Github", "Linkedin", "Mail"
  color String
  order Int    @default(0)
}

model Contact {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  email          String
  primaryPhone   String   @default("")
  secondaryPhone String?
  location       String
  resumeUrl      String
  updatedAt      DateTime @updatedAt
}
